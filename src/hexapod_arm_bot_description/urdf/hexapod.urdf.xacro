<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="hexapod_arm_bot">

  <!-- =============================== -->
  <!-- Parameters                      -->
  <!-- =============================== -->
  <xacro:property name="body_radius" value="0.2"/>
  <xacro:property name="body_length" value="1.0"/>
  
  <xacro:property name="arm_cyl_radius" value="0.04"/>
  <xacro:property name="arm_cyl_length" value="0.3"/>
  <xacro:property name="sphere_radius" value="0.06"/>

  <xacro:property name="joint_limit" value="1.57"/>
  <xacro:property name="joint_effort" value="10.0"/>
  <xacro:property name="joint_vel" value="1.0"/>

  <!-- =============================== -->
  <!-- Materials                       -->
  <!-- =============================== -->
  <material name="body_color">
    <color rgba="0.6 0.6 0.6 1.0"/>
  </material>
  <material name="arm_color">
    <color rgba="0.8 0.3 0.3 1.0"/>
  </material>
  <material name="joint_color">
    <color rgba="0.2 0.2 0.8 1.0"/>
  </material>

  <!-- =============================== -->
  <!-- Inertial Macros                 -->
  <!-- =============================== -->
  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0" 
               iyy="${m*(3*r*r+h*h)/12}" iyz="0" 
               izz="${m*r*r/2}" />
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${2*m*r*r/5}" ixy="0" ixz="0" 
               iyy="${2*m*r*r/5}" iyz="0" 
               izz="${2*m*r*r/5}" />
    </inertial>
  </xacro:macro>

  <xacro:macro name="dummy_inertia">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </xacro:macro>

  <!-- =============================== -->
  <!-- Base Link / Body                -->
  <!-- =============================== -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="body_link"/>
    <origin xyz="0 0 ${body_radius + 0.5}" rpy="0 ${pi/2} 0"/>
  </joint>

  <link name="body_link">
    <visual>
      <geometry>
        <cylinder radius="${body_radius}" length="${body_length}"/>
      </geometry>
      <material name="body_color"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${body_radius}" length="${body_length}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="10.0" r="${body_radius}" h="${body_length}"/>
  </link>

  <!-- ============================================== -->
  <!-- Gimbal Joint Macro (Sphere visually)           -->
  <!-- 3 DOFs: roll, pitch, yaw                       -->
  <!-- ============================================== -->
  <xacro:macro name="gimbal_joint" params="prefix parent child *origin">
    <!-- Roll Link (dummy) -->
    <link name="${prefix}_roll_link">
      <xacro:dummy_inertia/>
    </link>
    <joint name="${prefix}_roll_joint" type="revolute">
      <xacro:insert_block name="origin" />
      <parent link="${parent}"/>
      <child link="${prefix}_roll_link"/>
      <axis xyz="1 0 0"/>
      <limit lower="-${joint_limit}" upper="${joint_limit}" effort="${joint_effort}" velocity="${joint_vel}"/>
    </joint>

    <!-- Pitch Link (dummy) -->
    <link name="${prefix}_pitch_link">
      <xacro:dummy_inertia/>
    </link>
    <joint name="${prefix}_pitch_joint" type="revolute">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="${prefix}_roll_link"/>
      <child link="${prefix}_pitch_link"/>
      <axis xyz="0 1 0"/>
      <limit lower="-${joint_limit}" upper="${joint_limit}" effort="${joint_effort}" velocity="${joint_vel}"/>
    </joint>

    <!-- Yaw Link (Visually a Sphere) -->
    <link name="${prefix}_yaw_link">
      <visual>
        <geometry>
          <sphere radius="${sphere_radius}"/>
        </geometry>
        <material name="joint_color"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="${sphere_radius}"/>
      </geometry>
      </collision>
      <xacro:sphere_inertia m="0.5" r="${sphere_radius}"/>
    </link>
    <joint name="${prefix}_yaw_joint" type="revolute">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="${prefix}_pitch_link"/>
      <child link="${prefix}_yaw_link"/>
      <axis xyz="0 0 1"/>
      <limit lower="-${joint_limit}" upper="${joint_limit}" effort="${joint_effort}" velocity="${joint_vel}"/>
    </joint>

    <!-- Connection to the next cylinder -->
    <!-- The next cylinder starts exactly at the center of the sphere, so the child link's cylinder visual should have an offset of arm_cyl_length/2 -->
    <joint name="${prefix}_fixed_joint" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="${prefix}_yaw_link"/>
      <child link="${child}"/>
    </joint>
  </xacro:macro>

  <!-- ============================================== -->
  <!-- Arm Macro                                      -->
  <!-- ============================================== -->
  <xacro:macro name="arm" params="prefix parent *origin">
    
    <!-- Cylinder 1 -->
    <link name="${prefix}_cyl1">
      <visual>
        <origin xyz="0 0 ${arm_cyl_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${arm_cyl_radius}" length="${arm_cyl_length}"/>
        </geometry>
        <material name="arm_color"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${arm_cyl_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${arm_cyl_radius}" length="${arm_cyl_length}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="0.5" r="${arm_cyl_radius}" h="${arm_cyl_length}"/>
    </link>
    
    <joint name="${prefix}_base_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}"/>
      <child link="${prefix}_cyl1"/>
    </joint>

    <!-- Cylinder 2 via Gimbal 1 -->
    <link name="${prefix}_cyl2">
      <visual>
        <origin xyz="0 0 ${arm_cyl_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${arm_cyl_radius}" length="${arm_cyl_length}"/>
        </geometry>
        <material name="arm_color"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${arm_cyl_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${arm_cyl_radius}" length="${arm_cyl_length}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="0.5" r="${arm_cyl_radius}" h="${arm_cyl_length}"/>
    </link>
    <xacro:gimbal_joint prefix="${prefix}_g1" parent="${prefix}_cyl1" child="${prefix}_cyl2">
      <!-- Attached at the end of cylinder 1 -->
      <origin xyz="0 0 ${arm_cyl_length}" rpy="0 0 0"/>
    </xacro:gimbal_joint>

    <!-- Cylinder 3 via Gimbal 2 -->
    <link name="${prefix}_cyl3">
      <visual>
        <origin xyz="0 0 ${arm_cyl_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${arm_cyl_radius}" length="${arm_cyl_length}"/>
        </geometry>
        <material name="arm_color"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${arm_cyl_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${arm_cyl_radius}" length="${arm_cyl_length}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="0.5" r="${arm_cyl_radius}" h="${arm_cyl_length}"/>
    </link>
    <xacro:gimbal_joint prefix="${prefix}_g2" parent="${prefix}_cyl2" child="${prefix}_cyl3">
      <origin xyz="0 0 ${arm_cyl_length}" rpy="0 0 0"/>
    </xacro:gimbal_joint>

    <!-- Cylinder 4 via Gimbal 3 -->
    <link name="${prefix}_cyl4">
      <visual>
        <origin xyz="0 0 ${arm_cyl_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${arm_cyl_radius}" length="${arm_cyl_length}"/>
        </geometry>
        <material name="arm_color"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${arm_cyl_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${arm_cyl_radius}" length="${arm_cyl_length}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="0.5" r="${arm_cyl_radius}" h="${arm_cyl_length}"/>
    </link>
    <xacro:gimbal_joint prefix="${prefix}_g3" parent="${prefix}_cyl3" child="${prefix}_cyl4">
      <origin xyz="0 0 ${arm_cyl_length}" rpy="0 0 0"/>
    </xacro:gimbal_joint>

    <!-- Cylinder 5 via Gimbal 4 -->
    <link name="${prefix}_cyl5">
      <visual>
        <origin xyz="0 0 ${arm_cyl_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${arm_cyl_radius}" length="${arm_cyl_length}"/>
        </geometry>
        <material name="arm_color"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${arm_cyl_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${arm_cyl_radius}" length="${arm_cyl_length}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="0.5" r="${arm_cyl_radius}" h="${arm_cyl_length}"/>
    </link>
    <xacro:gimbal_joint prefix="${prefix}_g4" parent="${prefix}_cyl4" child="${prefix}_cyl5">
      <origin xyz="0 0 ${arm_cyl_length}" rpy="0 0 0"/>
    </xacro:gimbal_joint>

    <!-- Cylinder 6 via Gimbal 5 -->
    <link name="${prefix}_cyl6">
      <visual>
        <origin xyz="0 0 ${arm_cyl_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${arm_cyl_radius}" length="${arm_cyl_length}"/>
        </geometry>
        <material name="arm_color"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${arm_cyl_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${arm_cyl_radius}" length="${arm_cyl_length}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="0.5" r="${arm_cyl_radius}" h="${arm_cyl_length}"/>
    </link>
    <xacro:gimbal_joint prefix="${prefix}_g5" parent="${prefix}_cyl5" child="${prefix}_cyl6">
      <origin xyz="0 0 ${arm_cyl_length}" rpy="0 0 0"/>
    </xacro:gimbal_joint>

  </xacro:macro>

  <!-- ============================================== -->
  <!-- Attach 6 Arms                                  -->
  <!-- ============================================== -->
  <!-- Note: The body cylinder is oriented with its local Z along the global Y due to the base_joint's rpy="0 pi/2 0" (actually, cylinder local Z becomes global X).
       Let's check base_joint: rpy="0 pi/2 0", so body_link's local Z is global X, local X is global Z, local Y is global Y.
       The arm's base cylinder should point OUTWARDS from the body.
       Left side (global Y > 0) -> body_link local Y > 0.
       Right side (global Y < 0) -> body_link local Y < 0.
       Along the cylinder length (body Z): Z = -0.3, 0.0, 0.3.
  -->

  <!-- Left Arms (pointing +Y in global, or just set rpy suitably) -->
  <xacro:arm prefix="arm_L1" parent="body_link">
    <!-- Body Z is global X. Body Y is global Y. Body X is global -Z. -->
    <origin xyz="0 ${body_radius} -0.3" rpy="${pi/2} 0 0"/>
  </xacro:arm>
  <xacro:arm prefix="arm_L2" parent="body_link">
    <origin xyz="0 ${body_radius} 0" rpy="${pi/2} 0 0"/>
  </xacro:arm>
  <xacro:arm prefix="arm_L3" parent="body_link">
    <origin xyz="0 ${body_radius} 0.3" rpy="${pi/2} 0 0"/>
  </xacro:arm>

  <!-- Right Arms (pointing -Y in global) -->
  <xacro:arm prefix="arm_R1" parent="body_link">
    <origin xyz="0 -${body_radius} -0.3" rpy="-${pi/2} 0 0"/>
  </xacro:arm>
  <xacro:arm prefix="arm_R2" parent="body_link">
    <origin xyz="0 -${body_radius} 0" rpy="-${pi/2} 0 0"/>
  </xacro:arm>
  <xacro:arm prefix="arm_R3" parent="body_link">
    <origin xyz="0 -${body_radius} 0.3" rpy="-${pi/2} 0 0"/>
  </xacro:arm>

  <!-- ros2_control includes -->
  <xacro:include filename="hexapod.ros2_control.xacro" />
  <xacro:hexapod_ros2_control name="GazeboSystem" />

</robot>
